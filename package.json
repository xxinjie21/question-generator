	"description": "智学助手 — AI-powered question generator for Obsidian, supports Ollama/OpenAI, SM-2 spaced repetition, and exam-format export",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
